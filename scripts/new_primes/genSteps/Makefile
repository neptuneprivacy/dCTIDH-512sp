	$(SCC) -DBITS=512 -D'NAMESPACEBITS(x)=highctidh_512_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c fp512.S

fp2048.o: fp2048.S fp.h fp_namespace.h uintbig.h uintbig_namespace.h Makefile
	$(SCC) -DBITS=2048 -D'NAMESPACEBITS(x)=highctidh_2048_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c fp2048.S

uintbig512.o: uintbig512.S uintbig.h uintbig_namespace.h Makefile
	$(SCC) -DBITS=512 -D'NAMESPACEBITS(x)=highctidh_512_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c uintbig512.S

uintbig2048.o: uintbig2048.S uintbig.h uintbig_namespace.h Makefile
	$(SCC) -DBITS=2048 -D'NAMESPACEBITS(x)=highctidh_2048_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c uintbig2048.S

# ----- libhighctidh_untuned, size-independent but normally replaced by tuned functions:

libhighctidh_untuned.a: steps_untuned.o Makefile
	ar cr libhighctidh_untuned.a steps_untuned.o
	ranlib libhighctidh_untuned.a

steps_untuned.o: steps_untuned.c steps.h Makefile
	$(CC) -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c steps_untuned.c

# ----- libhighctidh_base, size-independent functions:

libhighctidh_base.a: steps.o random.o Makefile
	ar cr libhighctidh_base.a steps.o random.o
	ranlib libhighctidh_base.a

steps.o: steps.c steps.h Makefile
	$(CC) -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c steps.c

random.o: random.c random.h int32_sort.h randombytes.h Makefile
	$(CC) -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c random.c

# ----- functions that libhighctidh wants from a core crypto library:

libtest.a: randombytes.o int32_sort.o Makefile
	ar cr libtest.a  randombytes.o int32_sort.o
	ranlib libtest.a

randombytes.o: randombytes.c randombytes.h Makefile
	$(CC) -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c randombytes.c

int32_sort.o: int32_sort.c int32_sort.h Makefile
	$(CC) -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c int32_sort.c

# ----- ctidh (keygen + derive) for pk/sk test:
ctidh_api512.o: ctidh_api.c ctidh.h csidh.h fp.h primes.h Makefile
	$(CC) -DBITS=512 -D'NAMESPACEBITS(x)=highctidh_512_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c ctidh_api.c -o ctidh_api512.o

ctidh512.o: ctidh.c ctidh.h csidh.h fp.h primes.h Makefile
	$(CC) -DBITS=512 -D'NAMESPACEBITS(x)=highctidh_512_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c ctidh.c -o ctidh512.o

ctidh512: ctidh512.o ctidh_api512.o libhighctidh_512.a libhighctidh_base.a libhighctidh_untuned.a libtest.a
	$(CC) -o ctidh512 ctidh512.o ctidh_api512.o libhighctidh_512.a libhighctidh_base.a libhighctidh_untuned.a libtest.a

ctidh_demo512.o: ctidh_demo.c ctidh.h csidh.h fp.h primes.h cpucycles.h Makefile
	$(CC) -DBITS=512 -D'NAMESPACEBITS(x)=highctidh_512_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c ctidh_demo.c -o ctidh_demo512.o

ctidh-512.main: ctidh_demo512.o ctidh_api512.o libhighctidh_512.a libhighctidh_base.a libhighctidh_untuned.a libtest.a
	$(CC) -o ctidh-512.main ctidh_demo512.o ctidh_api512.o libhighctidh_512.a libhighctidh_base.a libhighctidh_untuned.a libtest.a

test_pubkey_compare512: test_pubkey_compare.c ctidh_api512.o \
libhighctidh_512.a libhighctidh_base.a libhighctidh_untuned.a libtest.a
	$(CC) -DBITS=512 -D'NAMESPACEBITS(x)=highctidh_512_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-o test_pubkey_compare512 test_pubkey_compare.c ctidh_api512.o \
		libhighctidh_512.a libhighctidh_base.a libhighctidh_untuned.a libtest.a

ctidh_api2048.o: ctidh_api.c ctidh.h csidh.h fp.h primes.h Makefile
	$(CC) -DBITS=2048 -D'NAMESPACEBITS(x)=highctidh_2048_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c ctidh_api.c -o ctidh_api2048.o

ctidh2048.o: ctidh.c ctidh.h csidh.h fp.h primes.h Makefile
	$(CC) -DBITS=2048 -D'NAMESPACEBITS(x)=highctidh_2048_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c ctidh.c -o ctidh2048.o

ctidh2048: ctidh2048.o ctidh_api2048.o libhighctidh_2048.a libhighctidh_base.a libhighctidh_untuned.a libtest.a
	$(CC) -o ctidh2048 ctidh2048.o ctidh_api2048.o libhighctidh_2048.a libhighctidh_base.a libhighctidh_untuned.a libtest.a

ctidh_demo2048.o: ctidh_demo.c ctidh.h csidh.h fp.h primes.h cpucycles.h Makefile
	$(CC) -DBITS=2048 -D'NAMESPACEBITS(x)=highctidh_2048_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-c ctidh_demo.c -o ctidh_demo2048.o

ctidh-2048.main: ctidh_demo2048.o ctidh_api2048.o libhighctidh_2048.a libhighctidh_base.a libhighctidh_untuned.a libtest.a
	$(CC) -o ctidh-2048.main ctidh_demo2048.o ctidh_api2048.o libhighctidh_2048.a libhighctidh_base.a libhighctidh_untuned.a libtest.a

test_pubkey_compare2048: test_pubkey_compare.c ctidh_api2048.o \
libhighctidh_2048.a libhighctidh_base.a libhighctidh_untuned.a libtest.a
	$(CC) -DBITS=2048 -D'NAMESPACEBITS(x)=highctidh_2048_##x' -D'NAMESPACEGENERIC(x)=highctidh_##x' \
		-o test_pubkey_compare2048 test_pubkey_compare.c ctidh_api2048.o \
		libhighctidh_2048.a libhighctidh_base.a libhighctidh_untuned.a libtest.a

# ----- compare pubkey generation 512 vs 2048 (run both and report):
test_pubkey_compare: test_pubkey_compare512 test_pubkey_compare2048
	@echo "--- CTIDH-512 ---"; ./test_pubkey_compare512
	@echo "--- CTIDH-2048 ---"; ./test_pubkey_compare2048
	@echo "--- Comparison: both keygen_ok=1 derive_match=1 and PK_SIZE differ ---"

# ----- ARM/mobile: use C sources instead of x86 .S (override when ARCH=arm64)
ifeq ($(ARCH),arm64)
